{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Fastify",
  "extends": "./base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "esModuleInterop": true,
    "strict": true
  },
  "include": ["src/**/*"]
}
